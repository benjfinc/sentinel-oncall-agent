# ---- Credentials ----------------------------------------------------------
COMPOSIO_API_KEY=
ANTHROPIC_API_KEY=
# The Composio user_id whose connected accounts (GitHub/Slack/Linear) Sentinel uses.
COMPOSIO_USER_ID=default

# ---- Model (single swap point) --------------------------------------------
# Fast, reliable tool-calling model for snappy demos. Bump only if needed.
AGENT_MODEL=claude-sonnet-4-6
# Optional: escalate ONLY the culprit-detection step to a stronger model.
# CULPRIT_MODEL=claude-opus-4-8
AGENT_MAX_TOKENS=4096

# ---- Target repo Sentinel operates on (the demo-service repo) --------------
TARGET_REPO_OWNER=your-github-username
TARGET_REPO_NAME=demo-service
TARGET_DEFAULT_BRANCH=main
COMMIT_SCAN_LIMIT=10

# ---- Discord / Linear -----------------------------------------------------
# Right-click your #incidents channel in Discord → Copy Channel ID
# (Enable Developer Mode first: Discord Settings → Advanced → Developer Mode)
DISCORD_CHANNEL_ID=
LINEAR_TEAM_ID=

# ---- CI polling -----------------------------------------------------------
CI_POLL_SECONDS=10
CI_POLL_MAX_ATTEMPTS=30

# ---- Behaviour ------------------------------------------------------------
# AUTO_MERGE=true means the merge is the autonomous finale (no human in loop).
AUTO_MERGE=true
TOOL_RETRIES=1
# pipeline (deterministic, recommended) | agentic (pure LLM tool-calling loop)
TRIGGER_MODE=pipeline

# ---- Storage --------------------------------------------------------------
TRACE_DB_PATH=sentinel_traces.sqlite
